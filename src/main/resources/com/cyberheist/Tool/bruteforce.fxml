<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>

<VBox xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cyberheist.Tools.BruteForceToolController"
      alignment="CENTER" spacing="20" styleClass="tool-detail-root">
    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <Label text="Brute Force" styleClass="title-label" />

    <HBox spacing="20" alignment="CENTER">
        <Label text="3000 Coins" styleClass="price-label" />
    </HBox>

    <ImageView fx:id="toolImage" fitHeight="300" fitWidth="300" />

    <Label fx:id="toolDescription" text="Crash through security by trying every possible combination—no finesse, just raw power.
Slow and noisy, but guaranteed to find a way in if given enough time" styleClass="description-label"/>

    <HBox spacing="20" alignment="CENTER">
        <Button fx:id="buyButton" text="Buy Tool" onAction="#handleBuyTool" styleClass="buy-button"/>
    </HBox>

    <Button fx:id="backButton" onAction="#handleBack" text="← BACK" />
</VBox>
