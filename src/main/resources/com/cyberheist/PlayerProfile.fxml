<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cyberheist.PlayerProfileController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="header">
            <children>
                <Button fx:id="backButton" onAction="#handleBack" styleClass="back-button" text="← Back" />
                <Label styleClass="page-title" text="Player Profile" />
            </children>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" styleClass="main-scroll">
            <content>
                <VBox spacing="20.0">
                    <children>
                        <!-- Profile Header Section -->
                        <HBox alignment="CENTER_LEFT" spacing="30.0" styleClass="profile-header">
                            <children>
                                <VBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <ImageView fx:id="profileImageView" fitHeight="120.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true" styleClass="profile-image" />
                                        <Button fx:id="changeProfilePicButton" onAction="#handleChangeProfilePic" styleClass="secondary-button" text="Change Picture" />
                                    </children>
                                </VBox>
                                <VBox spacing="10.0">
                                    <children>
                                        <Label fx:id="usernameLabel" styleClass="username-label" text="Username" />
                                        <Button fx:id="editProfileButton" onAction="#handleEditProfile" styleClass="secondary-button" text="Edit Profile" />
                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <children>
                                                <Label fx:id="levelLabel" styleClass="level-label" text="Level 1" />
                                                <Label fx:id="rankLabel" styleClass="rank-label" text="Rank" />
                                            </children>
                                        </HBox>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label fx:id="experienceLabel" styleClass="experience-label" text="0 / 100 XP" />
                                                <ProgressBar fx:id="experienceBar" prefWidth="250.0" progress="0.0" styleClass="experience-bar" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                        </HBox>

                        <!-- Statistics Section -->
                        <VBox spacing="15.0" styleClass="statistics-section">
                            <children>
                                <Label styleClass="section-title" text="Statistics" />
                                <GridPane hgap="20.0" vgap="15.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="10.0" prefHeight="60.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="60.0" vgrow="SOMETIMES" />
                                    </rowConstraints>
                                    <children>
                                        <VBox alignment="CENTER" spacing="5.0" styleClass="stat-box">
                                            <children>
                                                <Label fx:id="totalGamesLabel" styleClass="stat-value" text="0" />
                                                <Label styleClass="stat-label" text="Total Games" />
                                            </children>
                                        </VBox>
                                        <VBox alignment="CENTER" spacing="5.0" styleClass="stat-box" GridPane.columnIndex="1">
                                            <children>
                                                <Label fx:id="winsLabel" styleClass="stat-value win-color" text="0" />
                                                <Label styleClass="stat-label" text="Wins" />
                                            </children>
                                        </VBox>
                                        <VBox alignment="CENTER" spacing="5.0" styleClass="stat-box" GridPane.columnIndex="2">
                                            <children>
                                                <Label fx:id="lossesLabel" styleClass="stat-value loss-color" text="0" />
                                                <Label styleClass="stat-label" text="Losses" />
                                            </children>
                                        </VBox>
                                        <VBox alignment="CENTER" spacing="5.0" styleClass="stat-box" GridPane.columnIndex="3">
                                            <children>
                                                <Label fx:id="winRateLabel" styleClass="stat-value" text="0%" />
                                                <Label styleClass="stat-label" text="Win Rate" />
                                            </children>
                                        </VBox>
                                        <VBox alignment="CENTER" spacing="5.0" styleClass="stat-box" GridPane.rowIndex="1">
                                            <children>
                                                <Label fx:id="totalScoreLabel" styleClass="stat-value" text="0" />
                                                <Label styleClass="stat-label" text="Total Score" />
                                            </children>
                                        </VBox>
                                        <VBox alignment="CENTER" spacing="5.0" styleClass="stat-box" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                            <children>
                                                <Label fx:id="averageScoreLabel" styleClass="stat-value" text="0" />
                                                <Label styleClass="stat-label" text="Average Score" />
                                            </children>
                                        </VBox>
                                        <VBox alignment="CENTER" spacing="5.0" styleClass="stat-box" GridPane.columnIndex="2" GridPane.rowIndex="1">
                                            <children>
                                                <Label fx:id="playtimeLabel" styleClass="stat-value" text="0 hours" />
                                                <Label styleClass="stat-label" text="Playtime" />
                                            </children>
                                        </VBox>
                                    </children>
                                </GridPane>
                            </children>
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
                            </padding>
                        </VBox>

                        <!-- Game History Section -->
                        <VBox spacing="15.0" styleClass="history-section">
                            <children>
                                <Label styleClass="section-title" text="Recent Game History" />
                                <TableView fx:id="gameHistoryTable" prefHeight="300.0" styleClass="game-history-table">
                                    <columns>
                                        <TableColumn fx:id="gameTypeColumn" prefWidth="200.0" text="Game Type" />
                                        <TableColumn fx:id="resultColumn" prefWidth="80.0" text="Result" />
                                        <TableColumn fx:id="scoreColumn" prefWidth="100.0" text="Score" />
                                        <TableColumn fx:id="dateColumn" prefWidth="140.0" text="Date &amp; Time" />
                                        <TableColumn fx:id="durationColumn" prefWidth="100.0" text="Duration" />
                                    </columns>
                                </TableView>
                            </children>
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
                            </padding>
                        </VBox>
                    </children>
                    <padding>
                        <Insets bottom="20.0" />
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>