<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cyberheist.ToolsController"
      alignment="CENTER" spacing="20" styleClass="root">
    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <Label text="HACKING ARSENAL" styleClass="title-label" />

    <HBox spacing="20" alignment="CENTER">
        <Label fx:id="coinsLabel" text="Coins: 500" styleClass="coins-label" />
        <Label fx:id="diamondsLabel" text="Diamonds: 10" styleClass="diamonds-label" />
    </HBox>

    <HBox spacing="30" alignment="TOP_CENTER">
        <VBox spacing="15" alignment="TOP_CENTER" styleClass="container">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>
            <Label text="ATTACKING TOOLS" styleClass="subtitle-label" />
            <ScrollPane fitToWidth="true" maxHeight="400" hbarPolicy="NEVER">
                <VBox fx:id="attackingToolsBox" spacing="10" />
            </ScrollPane>
        </VBox>

        <VBox spacing="15" alignment="TOP_CENTER" styleClass="container">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>
            <Label text="DEFENSIVE TOOLS" styleClass="subtitle-label" />
            <ScrollPane fitToWidth="true" maxHeight="400" hbarPolicy="NEVER">
                <VBox fx:id="defensiveToolsBox" spacing="10" />
            </ScrollPane>
        </VBox>
    </HBox>

    <HBox spacing="20" alignment="CENTER">
        <Button fx:id="backButton" text="← BACK" onAction="#handleBack" styleClass="nav-button" />
        <Button fx:id="mainMenuButton" text="MAIN MENU" onAction="#handleMainMenu" styleClass="primary-button" />
    </HBox>

    <Label text="Access tools to enhance your hacking capabilities" styleClass="info-label" />
</VBox>