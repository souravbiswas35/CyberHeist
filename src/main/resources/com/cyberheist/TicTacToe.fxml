<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="675.0" prefWidth="519.0" spacing="20"
      styleClass="root" xmlns="http://javafx.com/javafx/23.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cyberheist.TicTacToeController">
    <padding>
        <Insets bottom="30" left="40" right="40" top="30"/>
    </padding>

    <Label styleClass="title-label" text="TIC TAC TOE PROTOCOL">
        <font>
            <Font name="System Bold" size="16.0"/>
        </font>
    </Label>

    <Label fx:id="statusLabel" styleClass="subtitle-label"
           text="Your Turn - Click to place X"/>

    <VBox alignment="CENTER" prefHeight="450.0" prefWidth="558.0"
          spacing="0" styleClass="game-container">
        <padding>
            <Insets bottom="20" left="20" right="20" top="20"/>
        </padding>

        <GridPane fx:id="gameGrid" alignment="CENTER"
                  hgap="0" vgap="0"
                  prefHeight="405.0" prefWidth="408.0"
                  style="-fx-border-color: #00FFFF; -fx-border-width: 0;"
                  styleClass="game-grid">
            <!-- 3 equal-width columns -->
            <columnConstraints>
                <ColumnConstraints percentWidth="33.33"/>
                <ColumnConstraints percentWidth="33.33"/>
                <ColumnConstraints percentWidth="33.33"/>
            </columnConstraints>
            <!-- 3 equal-height rows -->
            <rowConstraints>
                <RowConstraints percentHeight="33.33"/>
                <RowConstraints percentHeight="33.33"/>
                <RowConstraints percentHeight="33.33"/>
            </rowConstraints>

            <!-- Buttons now auto‐size to fill each cell -->
            <Button fx:id="btn00" styleClass="game-button"
                    GridPane.columnIndex="0" GridPane.rowIndex="0"
                    maxWidth="Infinity" maxHeight="Infinity"/>
            <Button fx:id="btn01" styleClass="game-button"
                    GridPane.columnIndex="1" GridPane.rowIndex="0"
                    maxWidth="Infinity" maxHeight="Infinity"/>
            <Button fx:id="btn02" styleClass="game-button"
                    GridPane.columnIndex="2" GridPane.rowIndex="0"
                    maxWidth="Infinity" maxHeight="Infinity"/>
            <Button fx:id="btn10" styleClass="game-button"
                    GridPane.columnIndex="0" GridPane.rowIndex="1"
                    maxWidth="Infinity" maxHeight="Infinity"/>
            <Button fx:id="btn11" styleClass="game-button"
                    GridPane.columnIndex="1" GridPane.rowIndex="1"
                    maxWidth="Infinity" maxHeight="Infinity"/>
            <Button fx:id="btn12" styleClass="game-button"
                    GridPane.columnIndex="2" GridPane.rowIndex="1"
                    maxWidth="Infinity" maxHeight="Infinity"/>
            <Button fx:id="btn20" styleClass="game-button"
                    GridPane.columnIndex="0" GridPane.rowIndex="2"
                    maxWidth="Infinity" maxHeight="Infinity"/>
            <Button fx:id="btn21" styleClass="game-button"
                    GridPane.columnIndex="1" GridPane.rowIndex="2"
                    maxWidth="Infinity" maxHeight="Infinity"/>
            <Button fx:id="btn22" styleClass="game-button"
                    GridPane.columnIndex="2" GridPane.rowIndex="2"
                    maxWidth="Infinity" maxHeight="Infinity"/>
        </GridPane>

        <Button fx:id="resetButton" onAction="#handleReset"
                styleClass="primary-button" text="RESET GAME"/>
    </VBox>

    <HBox alignment="CENTER" spacing="20">
        <Button fx:id="backButton" onAction="#handleBack" text="← BACK"/>
        <Button fx:id="mainMenuButton" onAction="#handleMainMenu"
                styleClass="primary-button" text="MAIN MENU"/>
    </HBox>

    <Label styleClass="info-label" text="Defeat the AI to earn 100 coins!"/>
</VBox>
