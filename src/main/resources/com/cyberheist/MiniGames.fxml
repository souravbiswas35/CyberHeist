<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20" styleClass="root" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cyberheist.MiniGamesController">
    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <Label styleClass="title-label" text="TRAINING PROTOCOLS" />
    <Label styleClass="subtitle-label" text="Earn coins to upgrade your hacking arsenal" />

    <GridPane alignment="CENTER" hgap="20" vgap="20">
        <Button fx:id="ticTacToeButton" onAction="#handleTicTacToe" styleClass="minigame-button" text="TIC TAC TOE&#10;100 Coins" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <Button fx:id="snakeButton" onAction="#handleSnake" styleClass="minigame-button" text="SNAKE GAME&#10;80 Coins" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        <Button fx:id="bubbleShooterButton" onAction="#handleBubbleShooter" styleClass="minigame-button" text="BUBBLE SHOOTER&#10;80 Coins" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <Button fx:id="tetrisButton" onAction="#handleTetris" styleClass="minigame-button" text="TETRIS&#10;100 Coins" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        <Button fx:id="wordGameButton" onAction="#handleWordGame" styleClass="minigame-button" text="WORD GAME&#10;100 Coins" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <Button fx:id="spaceGameButton" onAction="#handleSpaceGame" styleClass="minigame-button" text="SPACE GAME&#10;90 Coins" GridPane.columnIndex="1" GridPane.rowIndex="2" />
      <columnConstraints>
         <ColumnConstraints />
         <ColumnConstraints />
      </columnConstraints>
      <rowConstraints>
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
      </rowConstraints>
    </GridPane>

    <HBox alignment="CENTER" spacing="20">
        <Button fx:id="backButton" onAction="#handleBack" text="← BACK" />
        <Button fx:id="mainMenuButton" onAction="#handleMainMenu" styleClass="primary-button" text="MAIN MENU" />
    </HBox>

    <Label styleClass="info-label" text="Complete training modules to earn cryptocurrency..." />
</VBox>
