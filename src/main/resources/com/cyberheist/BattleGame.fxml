<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.cyberheist.BattleGameController"
            styleClass="cyber-bg">

    <!-- Top section with health bars -->
    <top>
        <VBox alignment="CENTER" spacing="10">
            <padding>
                <Insets top="20" bottom="10" left="20" right="20"/>
            </padding>

            <HBox alignment="CENTER" spacing="20">
                <!-- Player health bar -->
                <VBox alignment="CENTER" spacing="5">
                    <Label text="YOUR BASE" styleClass="health-label"/>
                    <StackPane>
                        <Rectangle width="400" height="30" styleClass="health-bg"/>
                        <Rectangle fx:id="playerHealthBar" width="400" height="30" styleClass="player-health"/>
                        <Label fx:id="playerHealthLabel" text="100%" styleClass="health-text"/>
                    </StackPane>
                </VBox>

                <!-- Timer Label -->
                <VBox alignment="CENTER" spacing="5">
                    <Label text="TIME REMAINING" styleClass="timer-title"/>
                    <Label fx:id="timerLabel" text="02:00" styleClass="timer-label"/>
                </VBox>

                <!-- Opponent health bar -->
                <VBox alignment="CENTER" spacing="5">
                    <Label text="ENEMY BASE" styleClass="health-label"/>
                    <StackPane>
                        <Rectangle width="400" height="30" styleClass="health-bg"/>
                        <Rectangle fx:id="opponentHealthBar" width="400" height="30" styleClass="opponent-health"/>
                        <Label fx:id="opponentHealthLabel" text="100%" styleClass="health-text"/>
                    </StackPane>
                </VBox>
            </HBox>

            <Label fx:id="statusLabel" text="Waiting for opponent..." styleClass="status-label"/>
        </VBox>
    </top>

    <!-- Center section with game field -->
    <center>
        <HBox alignment="CENTER" spacing="100">
            <!-- Player's base -->
            <VBox alignment="CENTER" spacing="10">
                <ImageView fx:id="playerBase" fitWidth="250" fitHeight="300" preserveRatio="true"/>
                <StackPane>
                    <Rectangle width="250" height="50" styleClass="treasure-bg"/>
                    <Label text="YOUR TREASURE" styleClass="treasure-label"/>
                </StackPane>
                <Label fx:id="playerXpLabel" text="ATTACK XP: 20 | DEFENSE XP: 15" styleClass="xp-label"/>
            </VBox>

            <!-- Battle animations area -->
            <VBox alignment="CENTER">
                <ImageView fx:id="battleAnimation" fitWidth="600" fitHeight="400" preserveRatio="true" visible="false"/>
            </VBox>

            <!-- Opponent's base -->
            <VBox alignment="CENTER" spacing="10">
                <ImageView fx:id="opponentBase" fitWidth="250" fitHeight="300" preserveRatio="true"/>
                <StackPane>
                    <Rectangle width="250" height="50" styleClass="treasure-bg"/>
                    <Label text="ENEMY TREASURE" styleClass="treasure-label"/>
                </StackPane>
                <Label fx:id="opponentStatusLabel" text="Waiting..." styleClass="status-label"/>
            </VBox>
        </HBox>
    </center>

    <!-- Bottom section with controls -->
    <bottom>
        <VBox alignment="CENTER" spacing="20">
            <padding>
                <Insets bottom="20" top="10" left="20" right="20"/>
            </padding>

            <!-- Game controls -->
            <HBox alignment="CENTER" spacing="50">
                <!-- Attack options -->
                <VBox spacing="10" alignment="CENTER">
                    <Label text="ATTACK" styleClass="section-title"/>
                    <ComboBox fx:id="attackTypeComboBox" prefWidth="200"/>
                    <Button fx:id="attackButton" text="LAUNCH ATTACK" styleClass="attack-button" onAction="#handleAttack" prefWidth="200"/>
                    <Label fx:id="attackXpLabel" text="Attack XP: 20" styleClass="xp-info-label"/>
                </VBox>

                <!-- Defense options -->
                <VBox spacing="10" alignment="CENTER">
                    <Label text="DEFENSE" styleClass="section-title"/>
                    <ComboBox fx:id="defenseTypeComboBox" prefWidth="200"/>
                    <Button fx:id="defenseButton" text="ACTIVATE DEFENSE" styleClass="defense-button" onAction="#handleDefense" prefWidth="200"/>
                    <Label fx:id="defenseXpLabel" text="Defense XP: 15" styleClass="xp-info-label"/>
                </VBox>
            </HBox>

            <!-- Ready button -->
            <HBox alignment="CENTER" spacing="20">
                <Button fx:id="readyButton" text="READY" styleClass="ready-button" onAction="#handleReady" prefWidth="200" prefHeight="50"/>
                <Button fx:id="playAIButton" text="PLAY AGAINST AI" styleClass="ai-button" prefWidth="200" prefHeight="50"/>
                <Button fx:id="rematchButton" text="REMATCH" styleClass="rematch-button" onAction="#handleRematch" prefWidth="200" prefHeight="50" visible="false"/>
                <Button fx:id="quitButton" text="QUIT GAME" onAction="#handleQuit" styleClass="secondary-button"/>

            </HBox>

            <!-- Game message area -->
            <TextArea fx:id="gameMessageArea" editable="false" prefHeight="100" styleClass="message-area"/>

            <!-- Navigation buttons -->
            <HBox alignment="CENTER" spacing="20">
                <Button fx:id="backButton" text="BACK TO MENU" styleClass="secondary-button" onAction="#handleBack"/>
                <Button fx:id="exitButton" text="EXIT TO ATTACK" onAction="#handleExitToAttack" styleClass="secondary-button"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>